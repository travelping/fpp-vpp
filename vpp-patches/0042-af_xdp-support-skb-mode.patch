From 44d979fb898e30e25b46a65bdb4127f4286ca7da Mon Sep 17 00:00:00 2001
From: Vladimir Zhigulin <vladimir.jigulin@travelping.com>
Date: Tue, 13 Jan 2026 09:30:50 +0100
Subject: [PATCH] af_xdp: support skb mode

---
 src/plugins/af_xdp/af_xdp.api | 1 +
 src/plugins/af_xdp/af_xdp.h   | 1 +
 src/plugins/af_xdp/api.c      | 2 ++
 src/plugins/af_xdp/cli.c      | 2 +-
 src/plugins/af_xdp/device.c   | 5 ++++-
 src/plugins/af_xdp/test_api.c | 2 ++
 src/plugins/af_xdp/unformat.c | 2 ++
 7 files changed, 13 insertions(+), 2 deletions(-)

diff --git a/src/plugins/af_xdp/af_xdp.api b/src/plugins/af_xdp/af_xdp.api
index 4c2908e20..ab21b8899 100644
--- a/src/plugins/af_xdp/af_xdp.api
+++ b/src/plugins/af_xdp/af_xdp.api
@@ -23,6 +23,7 @@ enum af_xdp_mode
   AF_XDP_API_MODE_AUTO = 0,
   AF_XDP_API_MODE_COPY = 1,
   AF_XDP_API_MODE_ZERO_COPY = 2,
+  AF_XDP_API_MODE_SKB = 3,
 };
 
 enumflag af_xdp_flag : u8
diff --git a/src/plugins/af_xdp/af_xdp.h b/src/plugins/af_xdp/af_xdp.h
index cf364fc86..f5bf354e7 100644
--- a/src/plugins/af_xdp/af_xdp.h
+++ b/src/plugins/af_xdp/af_xdp.h
@@ -143,6 +143,7 @@ typedef enum
   AF_XDP_MODE_AUTO = 0,
   AF_XDP_MODE_COPY = 1,
   AF_XDP_MODE_ZERO_COPY = 2,
+  AF_XDP_MODE_SKB = 3,
 } af_xdp_mode_t;
 
 typedef enum
diff --git a/src/plugins/af_xdp/api.c b/src/plugins/af_xdp/api.c
index 3e9a3fe25..8d3ff72a7 100644
--- a/src/plugins/af_xdp/api.c
+++ b/src/plugins/af_xdp/api.c
@@ -41,6 +41,8 @@ af_xdp_api_mode (vl_api_af_xdp_mode_t mode)
       return AF_XDP_MODE_COPY;
     case AF_XDP_API_MODE_ZERO_COPY:
       return AF_XDP_MODE_ZERO_COPY;
+    case AF_XDP_API_MODE_SKB:
+      return AF_XDP_MODE_SKB;
     }
   return AF_XDP_MODE_AUTO;
 }
diff --git a/src/plugins/af_xdp/cli.c b/src/plugins/af_xdp/cli.c
index 660725813..2dba2aa87 100644
--- a/src/plugins/af_xdp/cli.c
+++ b/src/plugins/af_xdp/cli.c
@@ -52,7 +52,7 @@ VLIB_CLI_COMMAND (af_xdp_create_command, static) = {
   .short_help =
     "create interface af_xdp <host-if linux-ifname> [name ifname] "
     "[rx-queue-size size] [tx-queue-size size] [num-rx-queues <num|all>] "
-    "[prog pathname] [netns ns] [zero-copy|no-zero-copy] [no-syscall-lock]",
+    "[prog pathname] [netns ns] [zero-copy|no-zero-copy|skb-mode] [no-syscall-lock]",
   .function = af_xdp_create_command_fn,
 };
 /* *INDENT-ON* */
diff --git a/src/plugins/af_xdp/device.c b/src/plugins/af_xdp/device.c
index da8b58c37..f4dab865f 100644
--- a/src/plugins/af_xdp/device.c
+++ b/src/plugins/af_xdp/device.c
@@ -339,9 +339,12 @@ af_xdp_create_queue (vlib_main_t *vm, af_xdp_create_if_args_t *args,
       break;
     case AF_XDP_MODE_ZERO_COPY:
       sock_config.bind_flags |= XDP_ZEROCOPY;
+    case AF_XDP_MODE_SKB:
+      sock_config.bind_flags |= XDP_COPY;
+      sock_config.xdp_flags = XDP_FLAGS_SKB_MODE;
       break;
     }
-  if (args->prog)
+  if (args->prog && args->mode != AF_XDP_MODE_SKB)
     sock_config.libbpf_flags = XSK_LIBBPF_FLAGS__INHIBIT_PROG_LOAD;
   if (xsk_socket__create
       (xsk, ad->linux_ifname, qid, *umem, rx, tx, &sock_config))
diff --git a/src/plugins/af_xdp/test_api.c b/src/plugins/af_xdp/test_api.c
index 581697e34..50dd97124 100644
--- a/src/plugins/af_xdp/test_api.c
+++ b/src/plugins/af_xdp/test_api.c
@@ -54,6 +54,8 @@ api_af_xdp_mode (af_xdp_mode_t mode)
       return AF_XDP_API_MODE_COPY;
     case AF_XDP_MODE_ZERO_COPY:
       return AF_XDP_API_MODE_ZERO_COPY;
+    case AF_XDP_MODE_SKB:
+      return AF_XDP_API_MODE_SKB;
     }
   return ~0;
 }
diff --git a/src/plugins/af_xdp/unformat.c b/src/plugins/af_xdp/unformat.c
index 8c0482d83..8ec855f35 100644
--- a/src/plugins/af_xdp/unformat.c
+++ b/src/plugins/af_xdp/unformat.c
@@ -52,6 +52,8 @@ unformat_af_xdp_create_if_args (unformat_input_t * input, va_list * vargs)
 	args->mode = AF_XDP_MODE_COPY;
       else if (unformat (line_input, "zero-copy"))
 	args->mode = AF_XDP_MODE_ZERO_COPY;
+      else if (unformat (line_input, "skb-mode"))
+	args->mode = AF_XDP_MODE_SKB;
       else if (unformat (line_input, "no-syscall-lock"))
 	args->flags |= AF_XDP_CREATE_FLAGS_NO_SYSCALL_LOCK;
       else
-- 
2.52.0

